{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "backend/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/backend/wsgi.py"
    },
    {
      "source": "/admin/:path*",
      "destination": "/backend/wsgi.py"
    },
    {
      "source": "/(css|js|images|html)/:path*",
      "destination": "/frontend/$1/:path*"
    }
  ]
}
